{
  "spacing": {
    "page": "p-4 md:p-6 lg:p-8",
    "section": "space-y-6",
    "card": "p-4 md:p-6",
    "stack": "gap-4",
    "inline": "gap-2"
  },
  "layout": {
    "container": "mx-auto max-w-7xl",
    "grid-2": "grid grid-cols-1 md:grid-cols-2 gap-6",
    "grid-3": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6",
    "grid-4": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4"
  },
  "colors": {
    "page-bg": "bg-gray-50",
    "card-bg": "bg-white",
    "text": "text-gray-900",
    "text-muted": "text-gray-500",
    "border": "border-gray-200"
  },
  "radius": {
    "card": "rounded-lg",
    "button": "rounded-md",
    "input": "rounded-md"
  },
  "shadow": {
    "card": "shadow-sm"
  }
}
